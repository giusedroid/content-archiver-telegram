# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOW_ALL_USERS=false

# Docker host paths.
# Compose mounts this repo into the container at /workspace/content-repo.
CONTENT_REPO_HOST_PATH=../content-archive-repo

# Set this to your host AWS config directory when using AWS_PROFILE.
# Windows example: C:/Users/Admin/.aws
# macOS/Linux example: /home/giuseppe/.aws
AWS_CONFIG_HOST_PATH=./.docker/aws-empty

# Content repository workspace.
# Local default points at the sibling repo; Docker overrides this to /workspace/content-repo.
CONTENT_REPO_PATH=../content-archive-repo

# Kiro headless
KIRO_CLI=kiro-cli
KIRO_API_KEY=
KIRO_TRUST_TOOLS=read,grep,write,bash
KIRO_TIMEOUT_SECONDS=600

# Git identity used by Kiro when it commits inside the content repo.
GIT_USER_NAME=Giuseppe Battista
GIT_USER_EMAIL=giusedroid@gmail.com

# Optional deterministic push after Kiro creates a new commit.
# Use a fine-grained GitHub PAT scoped to the content repository.
GIT_PUSH=false
GIT_REMOTE=origin
GIT_BRANCH=main
GITHUB_USERNAME=giusedroid
GITHUB_TOKEN=

# Local runtime cache for Telegram downloads before request handoff.
TELEGRAM_DOWNLOAD_DIR=.content-archiver-telegram/downloads

# Startup sync for the archive-owned MCP tools project.
ARCHIVE_TOOLS_SYNC=true
ARCHIVE_TOOLS_SYNC_ARGS=--locked --no-dev

# AWS/S3 used by MCP tools.
AWS_PROFILE=
AWS_REGION=
S3_BUCKET=
S3_PREFIX=raw/
S3_DRY_RUN=false

# Audio transcription used by MCP tools.
TRANSCRIPTION_PROVIDER=amazon-transcribe
AMAZON_TRANSCRIBE_LANGUAGE_CODE=
AMAZON_TRANSCRIBE_IDENTIFY_LANGUAGE=true
AMAZON_TRANSCRIBE_INPUT_PREFIX=transcribe/input/
AMAZON_TRANSCRIBE_OUTPUT_PREFIX=transcribe/output/
AMAZON_TRANSCRIBE_POLL_SECONDS=5
AMAZON_TRANSCRIBE_TIMEOUT_SECONDS=900

# OpenAI-compatible audio fallback, for Speaches/LM Studio/etc.
OPENAI_AUDIO_BASE_URL=http://localhost:8000/v1
OPENAI_AUDIO_API_KEY=cant-be-empty
WHISPER_MODEL=Systran/faster-distil-whisper-small.en

# Optional URL crawling.
FIRECRAWL_API_KEY=

# LanceDB/search tools. Keep EMBEDDING_PROVIDER=stub for local fallback search.
LANCEDB_URI=s3://content-archive/lancedb/content-os
LANCEDB_TABLE=captures
EMBEDDING_PROVIDER=stub
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=
OPENAI_API_KEY=
