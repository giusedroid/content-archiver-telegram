# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOW_ALL_USERS=false
TELEGRAM_CHATTY=true

# Docker content repository checkout.
# clone: clone/pull the content repo into a Docker named volume.
# bind: use an already-mounted checkout at CONTENT_REPO_PATH.
CONTENT_REPO_MODE=clone
CONTENT_REPO_GIT_URL=https://github.com/giusedroid/content-archive-repo.git

# Set this to your host AWS config directory when using AWS_PROFILE.
# Windows example: C:/Users/Admin/.aws
# macOS/Linux example: /home/giuseppe/.aws
AWS_CONFIG_HOST_PATH=./.docker/aws-empty

# Content repository workspace.
# Local CLI default points at the sibling repo; Docker overrides this to /workspace/content-repo.
CONTENT_REPO_PATH=../content-archive-repo

# Kiro headless
KIRO_CLI=kiro-cli
KIRO_API_KEY=
KIRO_TRUST_TOOLS=read,grep,write,@content-archiver-tools/crawl_url_to_markdown,@content-archiver-tools/extract_audio,@content-archiver-tools/extract_video_frames,@content-archiver-tools/index_lancedb,@content-archiver-tools/pdf_to_markdown,@content-archiver-tools/resize_image,@content-archiver-tools/semantic_search,@content-archiver-tools/transcribe_audio,@content-archiver-tools/upload_original_to_s3
KIRO_REQUIRE_MCP_STARTUP=false
KIRO_TIMEOUT_SECONDS=600
KIRO_VERBOSE=0
KIRO_LOG_DIR=.content-archiver-telegram/kiro-logs
LOG_LEVEL=INFO

# Telegram-owned MCP client preprocessing. Kiro-side MCP is disabled until Kiro CLI
# reliably exposes MCP tools to agents in non-interactive mode.
ARCHIVE_MCP_PREPROCESS=true
ARCHIVE_MCP_TIMEOUT_SECONDS=900

# Git identity used by the runtime when it commits inside the content repo.
GIT_USER_NAME=Giuseppe Battista
GIT_USER_EMAIL=giusedroid@gmail.com

# Capture delivery.
# commit: commit to the runtime content repo worktree, optionally push main.
# pull-request: create a per-request worktree/branch, push it, and open a GitHub PR.
CAPTURE_DELIVERY_MODE=commit
GIT_WORKTREE_ROOT=.content-archiver-telegram/worktrees
GIT_BRANCH_PREFIX=capture

# Optional deterministic push after the runtime creates a new direct-mode commit.
# Use a fine-grained GitHub PAT scoped to the content repository.
GIT_PUSH=false
GIT_REMOTE=origin
GIT_BRANCH=main
GITHUB_USERNAME=giusedroid
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_API_BASE_URL=https://api.github.com

# Local runtime cache for Telegram downloads before request handoff.
TELEGRAM_DOWNLOAD_DIR=.content-archiver-telegram/downloads

# Startup sync for the archive-owned MCP tools project.
ARCHIVE_TOOLS_SYNC=true
ARCHIVE_TOOLS_SYNC_ARGS=--locked --no-dev
CLEAN_GENERATED_INDEX_ON_STARTUP=true

# AWS/S3 used by MCP tools.
AWS_PROFILE=
AWS_REGION=
S3_BUCKET=
S3_PREFIX=raw/
S3_DRY_RUN=false

# Audio transcription used by MCP tools.
TRANSCRIPTION_PROVIDER=amazon-transcribe
AMAZON_TRANSCRIBE_LANGUAGE_CODE=
AMAZON_TRANSCRIBE_IDENTIFY_LANGUAGE=true
AMAZON_TRANSCRIBE_INPUT_PREFIX=transcribe/input/
AMAZON_TRANSCRIBE_OUTPUT_PREFIX=transcribe/output/
AMAZON_TRANSCRIBE_POLL_SECONDS=5
AMAZON_TRANSCRIBE_TIMEOUT_SECONDS=900

# OpenAI-compatible audio fallback, for Speaches/LM Studio/etc.
OPENAI_AUDIO_BASE_URL=http://localhost:8000/v1
OPENAI_AUDIO_API_KEY=cant-be-empty
WHISPER_MODEL=Systran/faster-distil-whisper-small.en

# Optional URL crawling.
FIRECRAWL_API_KEY=

# LanceDB/search tools. Keep EMBEDDING_PROVIDER=stub for local fallback search.
# Use EMBEDDING_PROVIDER=nvidia with NVIDIA Build/NIM nv-embed-v1 for real embeddings.
LANCEDB_URI=s3://content-archive/lancedb/content-os
LANCEDB_TABLE=captures
EMBEDDING_PROVIDER=stub
EMBEDDING_MODEL=nvidia/nv-embed-v1
OPENAI_BASE_URL=
OPENAI_API_KEY=
NVIDIA_API_KEY=
